{% extends "base.html" %}

{% block content %}
<section class="content-card">
    <h2>Saved Routes</h2>
    <p>Quick journeys based on your most frequent travel patterns.</p>

    <div class="card-grid">
        {% for item in saved_routes %}
        <div class="info-card">
            <h3>{{ item.label }}</h3>
            <p>{{ item.start }} → {{ item.destination }}</p>
        </div>
        {% endfor %}
    </div>
</section>
{% endblock %}
